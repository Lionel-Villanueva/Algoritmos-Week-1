// Entrada O(N)
int SumScores(int[] scores)
{
   // +1 Por asignacion
   int sum = 0;

   // +1 Por asignacion, +(N+1) comparaciones, +N incrementos
   for(int i = 0; i < scores.Length; i++)
   {
      // +2 Por Incremento y asignacion, +N Acceso a i
      sum += scores[i];
   }

    // +1 Por asignacion
    return sum;
}

