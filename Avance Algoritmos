//Entrada O(1)
int CalculateFinalDamage(int attack, int defense, float multiplier)
{
      // +1 asignacion, +1 operacion
      int baseDamage = attack - defense;
      int finalDamage = (int)(baseDamage * multiplier); // +1 asignacion, +1 operacion

      if (finalDamage < 0) // +1 comparacion
      {
            finalDamage = 0; // +1 asignacion
      }
      return finalDamage; // +1 llamada simple
}

