//Entrada O(N)
int CalculateInteractionsScore(int[] players)
{
    // +1 por asignacion
    int score = 0;
    // +1 por asignacion, +(N+1) comparaciones, +N incrementos
    for (int i = 0; i < players.Length; i++)
    {
        //N*(+1+N+1 por asignacion a variable no fija y incremento, +(N+1) comparaciones, +N incrementos)
        for(int j = i + 1; j < players.Length; j++)
        {
            //+1 asignacion, +1 asignacion, +N acceso, +1 incremento, +N acceso
            int interaction = players[i] + players[j];
            score += interaction; //+2 incremento y asignacion
        }

    }
    //+1 llamada simple
    return score;
}

