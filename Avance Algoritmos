// O(N^2)
int CountStrongerPairs(int[] powerLevels)
{
      int count = 0; // +1 asignacion

      // +1 asignacion, +(N+1) comparacion, +N incremento
      for (int i = 0; i < powerLevels.Length; i++)
      {
            for(int j = 0; j < powerLevels.Length; j++) // +1 asignacion, +(N+1) comparacion, +N incremento
            {
                  if(powerLevels[i] > powerLevels[j]) // +N acceso, +1 comparacion, +N acceso
                  {
                        count++; // +N incremento
                  }
            }
      }
      return count; // +1  llamada simple
}

T(N) = for INTERNO: N*(N+N+1+N+1+N+1+N) = N*(5N+3) = 5N^2+3N
     = for EXTERNO: 1+1+N+1+N+1+5N^2+3N
     = 5N^2+5N+4
O(N) = N^2



